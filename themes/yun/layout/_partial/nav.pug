//- layout/_partial/nav.pug
//- Valaxy 风格的顶部毛玻璃通栏导航 (内嵌搜索与移动端抽屉逻辑)

nav.valaxy-nav
  //- 1. 左侧：图标菜单
  .nav-left
    //- 📱 手机端：汉堡菜单
    a#mobile-menu-btn.nav-item(href='javascript:;', onclick="toggleSidebar()", title="菜单")
      +icon('ri:menu-line')
    
    //- 🏠 所有图标现在都直接放在这里，不分内外层
    a.nav-item(href=url_for('/'), title=__('menu.home'))
      +icon('ri:home-4-line')
      
    if theme.menu && theme.menu.list
      for item, name in theme.menu.list
        - var title = item.title || __('menu.' + (item.type || name))
        //- 过滤掉已经在上面显示的 home，且如果是手机端，隐藏这些图标
        if item.type !== 'home'
          a.nav-item.desktop-only-icon(href=url_for(item.path), title=title)
            if item.icon
              +icon(item.icon)
            else
              span= title

    a.nav-item.desktop-only-icon(href=url_for('/links/'), title="我的小伙伴们")
      +icon('ri:links-line')
    a.nav-item.desktop-only-icon(href=url_for('/girls/'), title="她们都是我的翅膀")
      +icon('ri:women-line')

  //- 2. 中间：动态标题
  .nav-center#nav-center
    .nav-title-wrapper
      a.site-name(href=url_for('/'))= config.title
      if is_post() || is_page()
        span.article-title(onclick="window.scrollTo({top: 0, behavior: 'smooth'})", title="点击回到顶部")= page.title

  //- 3. 右侧：功能按钮
  .nav-right
    a#toggle-mode-btn.nav-item(href='javascript:;', title="切换主题")
      +icon('ri:contrast-2-line')
    a.nav-item(href='javascript:;', title="搜索", onclick="openMySearch()")
      +icon('ri:search-line')

//- 📱 手机端专属：全屏变暗遮罩层 & 右下角目录悬浮按钮
#mobile-overlay(onclick="closeAllDrawers()")
#mobile-toc-btn(onclick="toggleToc()", title="文章目录")
  +icon('ri:list-unordered')

//- 🚀 动态效果与抽屉控制 JS
script.
  // 滚动切换标题
  document.addEventListener('DOMContentLoaded', function() {
    const navCenter = document.getElementById('nav-center');
    if (navCenter && document.querySelector('.article-title')) {
      window.addEventListener('scroll', function() {
        if (window.scrollY > 150) { navCenter.classList.add('show-article-title'); } 
        else { navCenter.classList.remove('show-article-title'); }
      });
    }
  });

  // 手机端抽屉开关逻辑
  window.toggleSidebar = function() { document.body.classList.toggle('sidebar-open'); };
  window.toggleToc = function() { document.body.classList.toggle('toc-open'); };
  window.closeAllDrawers = function() { document.body.classList.remove('sidebar-open', 'toc-open'); };

//- ==============================================================
//- 搜索弹窗代码 (保持原样不变)
//- ==============================================================
#my-search-modal(style="display:none;")
  .search-modal-bg(onclick="closeMySearch()")
  .search-modal-content
    .search-header
      span.search-icon
        +icon('ri:search-line')
      input#my-search-input(type="text", placeholder="输入关键词搜索全站...")
      span#my-search-close.close-btn(onclick="closeMySearch()")
        +icon('ri:close-line')
    #my-search-results.search-results

style.
  #my-search-modal { position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 9999; display: flex; justify-content: center; padding-top: 12vh; }
  .search-modal-bg { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.3); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); }
  .search-modal-content { position: relative; width: 90%; max-width: 650px; background: var(--my-card-bg, #ffffff); border-radius: 16px; box-shadow: 0 10px 40px rgba(0,0,0,0.15); overflow: hidden; animation: slideDown 0.3s ease; display: flex; flex-direction: column; max-height: 75vh; }
  @keyframes slideDown { from { opacity: 0; transform: translateY(-20px); } to { opacity: 1; transform: translateY(0); } }
  .search-header { display: flex; align-items: center; padding: 20px 24px; border-bottom: 1px solid rgba(150,150,150,0.1); }
  .search-header input { flex: 1; border: none; background: transparent; outline: none; font-size: 1.1rem; color: var(--hty-text-color); margin: 0 15px; }
  .search-header .close-btn { cursor: pointer; font-size: 1.4rem; opacity: 0.6; transition: all 0.2s; }
  .search-header .close-btn:hover { opacity: 1; color: var(--hty-primary-color); transform: rotate(90deg); }
  .search-results { overflow-y: auto; padding: 10px 24px 20px; }
  .search-result-item { display: block; padding: 15px 0; border-bottom: 1px dashed rgba(150,150,150,0.1); text-decoration: none; color: var(--hty-text-color); transition: all 0.2s; }
  .search-result-item:hover { transform: translateX(5px); }
  .search-result-title { font-weight: bold; font-size: 1.1rem; margin-bottom: 8px; color: var(--hty-primary-color); }
  .search-result-content { font-size: 0.9rem; opacity: 0.7; line-height: 1.6; }
  .search-keyword { color: #ff5252; font-weight: bold; }

script.
  let mySearchData = null;
  window.openMySearch = function() {
    document.getElementById('my-search-modal').style.display = 'flex';
    setTimeout(() => document.getElementById('my-search-input').focus(), 100);
    if (!mySearchData) {
      fetch('/search.xml').then(res => res.text()).then(str => {
        const parser = new DOMParser();
        const entries = parser.parseFromString(str, "text/xml").getElementsByTagName("entry");
        mySearchData = Array.from(entries).map(entry => ({
          title: entry.getElementsByTagName('title')[0]?.textContent || '',
          content: entry.getElementsByTagName('content')[0]?.textContent.replace(/<[^>]+>/g, '') || '',
          url: entry.getElementsByTagName('url')[0]?.textContent || ''
        }));
      }).catch(err => console.error("搜索数据加载失败:", err));
    }
  };
  window.closeMySearch = function() {
    document.getElementById('my-search-modal').style.display = 'none';
    document.getElementById('my-search-input').value = '';
    document.getElementById('my-search-results').innerHTML = '';
  };
  document.addEventListener('DOMContentLoaded', function() {
    const input = document.getElementById('my-search-input');
    if(input) {
      input.addEventListener('input', function() {
        const keyword = this.value.toLowerCase().trim();
        const results = document.getElementById('my-search-results');
        if (!keyword) { results.innerHTML = ''; return; }
        if (!mySearchData) return;
        const matched = mySearchData.filter(item => item.title.toLowerCase().includes(keyword) || item.content.toLowerCase().includes(keyword));
        if (matched.length === 0) { results.innerHTML = '<div style="padding:30px;text-align:center;opacity:0.5;">呜呜，什么都没有找到...</div>'; return; }
        results.innerHTML = matched.map(item => {
          const reg = new RegExp(keyword, 'gi');
          const title = item.title.replace(reg, match => `<span class="search-keyword">${match}</span>`);
          let content = item.content;
          const index = content.toLowerCase().indexOf(keyword);
          if (index > -1) {
            let start = Math.max(0, index - 30);
            let end = Math.min(content.length, index + 30);
            content = (start > 0 ? '...' : '') + content.substring(start, end) + (end < content.length ? '...' : '');
            content = content.replace(reg, match => `<span class="search-keyword">${match}</span>`);
          } else { content = content.substring(0, 60) + '...'; }
          return `<a href="${item.url}" class="search-result-item"><div class="search-result-title">${title}</div><div class="search-result-content">${content}</div></a>`;
        }).join('');
      });
    }
  });
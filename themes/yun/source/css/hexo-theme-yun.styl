// var
@import '_variables/*';
// mixin
@import '_mixins/*';
// global
@import '_global';
@import '_layout/*';
// component
@import '_components/*';
@import '_components/*/*';
// widget
@import '_widget';
// helper
@import '_helper';
// extend page
@import '_extend/tags';

if (hexo-config('albums.enable')) {
  @import '_extend/albums';
}

if (hexo-config('girls.enable')) {
  @import '_extend/girls';
}

if (hexo-config('custom.style')) {
  @import '../../../' + hexo-config('custom.style');
}

/* ================================================= */
/* 💎 究极版：完美三栏 + APP级侧滑抽屉 + 像素级排版 */
/* ================================================= */

:root {
  --my-card-bg: #ffffff;
  --my-radius: 16px;
  --my-shadow: 0 4px 24px -6px rgba(0, 0, 0, 0.08);
  --nav-height: 60px;
  --font-family-sans: "PingFang SC", "Microsoft YaHei", "Helvetica Neue", Helvetica, Arial, sans-serif !important;
  --font-family-serif: "Noto Serif SC", "Source Han Serif SC", "Songti SC", serif !important;
  --my-text-body: #2c3e50;
  --my-text-heading: #1a1a1a;
  --my-text-quote: #6a737d;
  --my-quote-bg: rgba(150, 150, 150, 0.05);
  --my-border-color: rgba(150, 150, 150, 0.15);
}

html.dark {
  --my-card-bg: #1e1e20;
  --my-shadow: 0 4px 24px -6px rgba(0, 0, 0, 0.4);
  --my-text-body: #c9d1d9;
  --my-text-heading: #e6edf3;
  --my-text-quote: #8b949e;
  --my-quote-bg: rgba(255, 255, 255, 0.05);
  --my-border-color: rgba(255, 255, 255, 0.1);
}

/* =============================================== */
/* 🌟 1. 顶部通栏导航栏 */
/* =============================================== */
.valaxy-nav {
  position: fixed; top: 0; left: 0; right: 0; height: var(--nav-height);
  background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(0, 0, 0, 0.05); padding: 0 24px; 
  z-index: 3000 !important; /* 确保导航栏在最顶层 */
  transition: all 0.3s ease;
  display: grid !important; grid-template-columns: 1fr auto 1fr !important; align-items: center !important;
}
html.dark .valaxy-nav { background: rgba(30, 30, 32, 0.7); border-bottom: 1px solid rgba(255, 255, 255, 0.05); }

.valaxy-nav .nav-left, .valaxy-nav .nav-right { display: flex !important; align-items: center !important; gap: 20px !important; }
.valaxy-nav .nav-left { justify-content: flex-start !important; }
.valaxy-nav .nav-right { justify-content: flex-end !important; }

.valaxy-nav .nav-center {
  position: static !important; transform: none !important; width: auto !important; min-width: 300px;
  height: var(--nav-height) !important; overflow: hidden !important; display: flex; justify-content: center;
  align-items: flex-start; margin: 0 !important; padding: 0 !important;
}
.nav-title-wrapper { display: flex; flex-direction: column; width: 100%; transform: translateY(0); transition: transform 0.4s cubic-bezier(0.25, 0.8, 0.25, 1); }
.nav-center.show-article-title .nav-title-wrapper { transform: translateY(-60px); }

.valaxy-nav .site-name, .valaxy-nav .article-title {
  height: var(--nav-height); line-height: var(--nav-height); display: block; text-align: center !important;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis; width: 100%; margin: 0 !important; padding: 0 !important;
  font-family: var(--font-family-serif) !important; font-size: 1.15rem !important; font-weight: bold !important;
  letter-spacing: 2px !important; color: var(--my-text-heading) !important; text-decoration: none !important;
}
.valaxy-nav .article-title { cursor: pointer; transition: opacity 0.3s ease; }
.valaxy-nav .article-title:hover { opacity: 0.6; }

.valaxy-nav .nav-item {
  color: var(--my-text-body); font-size: 1.5rem !important; opacity: 0.6; transition: all 0.2s;
  display: inline-flex !important; align-items: center !important; justify-content: center !important; padding: 5px !important;
}
.valaxy-nav .nav-item:hover { opacity: 1; color: var(--hty-primary-color); transform: scale(1.15); }
.valaxy-nav .nav-item svg { width: 1.6rem !important; height: 1.6rem !important; stroke-width: 1.5 !important; }
.valaxy-nav .nav-item span { font-size: 1.05rem !important; margin-left: 6px !important; }

/* =============================================== */
/* 🏗️ 2. 全局排版与 Grid 三栏卡片 */
/* =============================================== */
body:not(.is-home) {
  #menu-btn, .sidebar #toggle-mode-btn { display: none !important; }

  @media screen and (min-width: 1200px) {
    .container {
      display: grid !important; justify-content: center !important;
      grid-template-columns: 280px minmax(0, 1fr) 260px !important; grid-template-rows: auto auto !important;
      gap: 20px !important; max-width: 95vw !important; margin: 90px auto 40px auto !important;
      padding: 0 20px !important; align-items: start;
    }
    footer, #footer { grid-column: 1 / -1; grid-row: 3 !important; margin-top: 40px !important; }
  }

  #content {
    grid-column: 2 !important; grid-row: 2 !important; width: 100% !important; min-width: 0 !important; max-width: none !important;
    box-sizing: border-box !important; background: var(--my-card-bg) !important; border-radius: var(--my-radius) !important;
    box-shadow: var(--my-shadow) !important; padding: 40px 30px !important; margin: 0 !important;
  }

  .sidebar {
    grid-column: 1 !important; grid-row: 2 !important; position: sticky !important; top: 90px !important;
    box-sizing: border-box !important; background: var(--my-card-bg) !important; border-right: none !important;
    border-radius: var(--my-radius) !important; box-shadow: var(--my-shadow) !important; padding: 30px 20px !important;
    margin: 0 !important; width: auto !important;
  }
}

/* 电脑端右侧目录 */
.right-sidebar {
  grid-column: 3 !important; grid-row: 2 !important; position: sticky; top: 90px !important;
  box-sizing: border-box !important; background: var(--my-card-bg) !important; border-radius: var(--my-radius) !important;
  box-shadow: var(--my-shadow) !important; padding: 20px 16px; margin: 0 !important; max-height: calc(100vh - 120px); overflow-y: auto;
}
.right-sidebar::before {
  content: "文章目录"; display: block; font-size: 1rem; font-weight: bold; color: var(--my-text-heading);
  text-align: center; margin-bottom: 20px; padding-bottom: 15px; border-bottom: 1px dashed var(--my-border-color);
}
.right-sidebar ol, .right-sidebar ul { list-style: none !important; padding-left: 0 !important; margin: 0 !important; }
.right-sidebar .toc-number { display: none !important; }
.right-sidebar .toc-child { padding-left: 15px !important; }
.right-sidebar li.toc-item { margin-bottom: 10px !important; line-height: 1.4 !important; }
.right-sidebar a.toc-link {
  font-size: 0.9rem !important; color: var(--my-text-body) !important; opacity: 0.7; text-decoration: none !important;
  border-bottom: none !important; display: block; transition: all 0.2s ease;
}
.right-sidebar a.toc-link:hover, .right-sidebar a.toc-link.active { opacity: 1; color: var(--hty-primary-color) !important; transform: translateX(3px); }

/* =============================================== */
/* 📱 3. 手机端适配：APP 级侧边双抽屉交互 */
/* =============================================== */
@media screen and (max-width: 1199px) {
  .valaxy-nav .nav-center { display: none !important; }
  body:not(.is-home) .container { display: block !important; padding: 0 10px !important; margin-top: 80px !important; }
  body:not(.is-home) .sidebar { position: relative !important; top: 0 !important; width: 100% !important; margin: 20px auto !important; }
  body:not(.is-home) #content { margin: 20px 0 !important; padding: 20px 15px !important; }
}

/* 解除宽度封印（防溢出加强版） */
body:not(.is-home) #content .post-card, body:not(.is-home) #content .post-block,
body:not(.is-home) #content .post-content, body:not(.is-home) #content .markdown-body {
  max-width: 100% !important; width: auto !important; box-sizing: border-box !important; padding: 0 !important; margin: 0 !important; 
}

/* 默认在电脑端隐藏手机特有组件 */
#mobile-menu-btn, #mobile-overlay, #mobile-toc-btn { display: none !important; }

@media screen and (max-width: 768px) {
  /* 导航栏挤压处理 */
  .valaxy-nav { display: flex !important; justify-content: space-between !important; grid-template-columns: none !important; padding: 0 10px !important; }
  .valaxy-nav .nav-left, .valaxy-nav .nav-right { flex: 0 0 auto !important; gap: 4px !important; }
  
  /* 暴力只留汉堡和Home */
  .valaxy-nav .nav-left .nav-item { display: none !important; }
  .valaxy-nav .nav-left #mobile-menu-btn,
  .valaxy-nav .nav-left .nav-item:nth-child(2) { display: inline-flex !important; }
  
  .desktop-nav-links { display: none !important; } .desktop-only-icon { display: none !important; }

  /* 居中标题 */
  .valaxy-nav .nav-center {
    position: absolute !important; left: 50% !important; top: 0; transform: translateX(-50%) !important; width: 40% !important; 
    display: flex !important; justify-content: center !important; pointer-events: none; 
  }
  .valaxy-nav .article-title { display: none !important; } 
  .valaxy-nav .site-name { font-size: 1rem !important; letter-spacing: 0px !important; }
  .valaxy-nav .nav-item { padding: 5px !important; }
  .valaxy-nav .nav-item svg { width: 1.25rem !important; height: 1.25rem !important; }

  /* --- 关键：JS调用的暗黑遮罩层 --- */
  #mobile-overlay {
    display: block !important; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px); z-index: 2000; opacity: 0; visibility: hidden; transition: all 0.3s ease;
  }
  body.sidebar-open #mobile-overlay, body.toc-open #mobile-overlay { opacity: 1; visibility: visible; }

  /* --- 左侧抽屉 (汉堡菜单呼出) --- */
  body:not(.is-home) .sidebar {
    position: fixed !important; top: 0 !important; left: -320px !important; width: 280px !important; height: 100vh !important;
    z-index: 2001 !important; margin: 0 !important; border-radius: 0 20px 20px 0 !important; 
    transition: transform 0.35s cubic-bezier(0.25, 0.8, 0.25, 1) !important; overflow-y: auto; padding-top: 50px !important; 
  }
  body.sidebar-open .sidebar { transform: translateX(320px) !important; }

  /* --- 右侧抽屉 (悬浮按钮呼出) --- */
  .right-sidebar {
    display: block !important; position: fixed !important; top: 0 !important; right: -320px !important; width: 260px !important;
    height: 100vh !important; z-index: 2001 !important; margin: 0 !important; border-radius: 20px 0 0 20px !important;
    transition: transform 0.35s cubic-bezier(0.25, 0.8, 0.25, 1) !important; padding-top: 50px !important;
  }
  body.toc-open .right-sidebar { transform: translateX(-320px) !important; }

  /* --- 关键：JS调用的悬浮目录按钮 --- */
  #mobile-toc-btn {
    display: flex !important; position: fixed; bottom: 30px; right: 20px; width: 48px; height: 48px;
    background: var(--my-card-bg); border-radius: 50%; box-shadow: 0 8px 24px rgba(0,0,0,0.15); z-index: 1999;
    justify-content: center; align-items: center; color: var(--hty-primary-color); cursor: pointer; transition: transform 0.2s;
  }
  #mobile-toc-btn:active { transform: scale(0.9); }
}

/* ================================================= */
/* 💻 4. 修复：代码块防溢出与强制折行 */
/* ================================================= */
.markdown-body pre, 
.markdown-body .highlight pre,
.markdown-body .highlight code,
.markdown-body .highlight table td.code pre {
  white-space: pre-wrap !important; 
  word-break: break-all !important; 
  overflow-wrap: anywhere !important;
  max-width: 100% !important; 
  width: 100% !important; 
  box-sizing: border-box !important;
  overflow-x: hidden !important; 
  padding-bottom: 5px !important; 
}
.markdown-body .highlight::-webkit-scrollbar, .markdown-body pre::-webkit-scrollbar { height: 6px !important; }
.markdown-body .highlight::-webkit-scrollbar-thumb, .markdown-body pre::-webkit-scrollbar-thumb { background: rgba(150, 150, 150, 0.4) !important; border-radius: 4px !important; }
.markdown-body .highlight::-webkit-scrollbar-track, .markdown-body pre::-webkit-scrollbar-track { background: transparent !important; }

/* =============================================== */
/* ✒️ 5. 终极排版与字体质感升级 (完美黑夜模式) */
/* =============================================== */

@import url('https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@700;900&display=swap');

body {
  font-family: var(--font-family-sans) !important;
  color: var(--my-text-body) !important;
  -webkit-font-smoothing: antialiased !important; 
  -moz-osx-font-smoothing: grayscale !important;
}

.markdown-body {
  font-family: var(--font-family-sans) !important;
  font-size: 16px !important;            
  line-height: 1.85 !important;          
  letter-spacing: 0.04em !important;     
  color: var(--my-text-body) !important; 
  box-sizing: border-box !important; 
}

.markdown-body p { margin-top: 0 !important; margin-bottom: 1.6em !important; }
.markdown-body ul, .markdown-body ol { margin-bottom: 1.6em !important; line-height: 1.85 !important; }
.markdown-body li { margin-bottom: 0.5em !important; }

.markdown-body h1, .markdown-body h2, .markdown-body h3,
.markdown-body h4, .markdown-body h5, .markdown-body h6,
.post-title, .site-name, .article-title, .right-sidebar::before {
  font-family: var(--font-family-serif) !important;
  font-weight: 900 !important;
  color: var(--my-text-heading) !important; 
}

/* 1. 只有文章页里真正的 H1 主标题才放大居中，展现气势 */
h1.post-title {
  font-size: 2.2rem !important;
  text-align: center !important;
  margin-bottom: 1rem !important;
  letter-spacing: 0.05em !important;
  display: block !important;
  width: 100%;
}

/* 2. 归档页、标签页时间轴里的辅助标题：精巧、靠左 */
.archive .post-title,
.category .post-title,
.tag .post-title {
  font-size: 1.15rem !important;
  text-align: left !important;
  margin-bottom: 0 !important;
  letter-spacing: 0 !important;
}

/* 3. 首页文章卡片里的标题：大小适中、居中对齐 */
.post-card .post-title {
  font-size: 1.4rem !important;   /* 比归档大，比文章内H1小 */
  text-align: center !important;  /* 恢复居中，和下方的日期按钮对齐 */
  margin-bottom: 0.5rem !important;
  letter-spacing: 0 !important;
  display: block !important;
  width: 100%;
}
.post-meta { text-align: center !important; margin-bottom: 3.5rem !important; font-family: var(--font-family-sans) !important; }

.markdown-body h2 {
  font-size: 1.6rem !important; margin-top: 3.5rem !important; margin-bottom: 1.5rem !important;
  padding-bottom: 0.4em !important; border-bottom: 1px solid var(--my-border-color) !important; 
}
.markdown-body h3 { font-size: 1.3rem !important; margin-top: 2.5rem !important; margin-bottom: 1.2rem !important; }

.markdown-body blockquote {
  margin: 2.5rem 0 !important; padding: 1.2rem 1.5rem !important;
  border-left: 4px solid var(--hty-primary-color) !important; 
  background-color: var(--my-quote-bg) !important;     
  border-radius: 0 8px 8px 0 !important;
  color: var(--my-text-quote) !important;              
  font-size: 0.95em !important;
}
.markdown-body blockquote p { margin-bottom: 0 !important; }
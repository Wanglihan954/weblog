/* ================================================= */
/* 💎 终极版：Valaxy 风格三栏卡片 + 毛玻璃悬浮通栏导航 */
/* (已清理所有重复冗余代码，完美居中，字体绝对统一) */
/* ================================================= */

:root {
  --my-card-bg: #ffffff;
  --my-radius: 16px;
  --my-shadow: 0 4px 24px -6px rgba(0, 0, 0, 0.08);
  --nav-height: 60px;
}
html.dark {
  --my-card-bg: #1e1e20;
  --my-shadow: 0 4px 24px -6px rgba(0, 0, 0, 0.4);
}

/* =============================================== */
/* 🌟 1. 顶部毛玻璃通栏导航栏 (.valaxy-nav) */
/* =============================================== */
.valaxy-nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  height: var(--nav-height);
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(0, 0, 0, 0.05);
  padding: 0 24px;
  z-index: 1000;
  transition: all 0.3s ease;
  
  /* 👇 核心修复：使用 Grid 强制绝对对称，天王老子来了也挤不歪 */
  display: grid !important;
  grid-template-columns: 1fr auto 1fr !important; /* 左右两边各1等份，中间自适应 */
  align-items: center !important;
}
html.dark .valaxy-nav {
  background: rgba(30, 30, 32, 0.7);
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

/* --- 导航栏左右布局：分别靠左右对齐 --- */
.valaxy-nav .nav-left,
.valaxy-nav .nav-right {
  display: flex !important;
  align-items: center !important;
  gap: 20px !important;
}
.valaxy-nav .nav-left { justify-content: flex-start !important; }
.valaxy-nav .nav-right { justify-content: flex-end !important; }

/* --- 导航栏中间标题：解除旧封印，完美融入网格 --- */
.valaxy-nav .nav-center {
  position: static !important; /* 废弃容易出 bug 的绝对定位 */
  transform: none !important;
  width: auto !important; /* 让它根据文字自然撑开 */
  min-width: 300px; /* 给标题留足呼吸空间 */
  height: var(--nav-height) !important;
  overflow: hidden !important;
  display: flex;
  justify-content: center;
  align-items: flex-start;
  margin: 0 !important;
  padding: 0 !important;
}
.nav-title-wrapper {
  display: flex;
  flex-direction: column;
  width: 100%;
  transform: translateY(0);
  transition: transform 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
}
.nav-center.show-article-title .nav-title-wrapper {
  transform: translateY(-60px); 
}

/* --- 网站名 & 文章标题字体 --- */
.valaxy-nav .site-name,
.valaxy-nav .article-title {
  height: var(--nav-height);
  line-height: var(--nav-height);
  display: block;
  text-align: center !important;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  width: 100%;
  margin: 0 !important;
  padding: 0 !important;
  font-family: var(--font-family-serif, serif) !important; 
  font-size: 1.15rem !important;
  font-weight: bold !important;
  letter-spacing: 2px !important;
  color: var(--hty-text-color) !important;
  text-decoration: none !important;
}
.valaxy-nav .article-title {
  cursor: pointer;
  transition: opacity 0.3s ease;
}
.valaxy-nav .article-title:hover { opacity: 0.6; }

/* --- 导航栏图标按钮精细化 --- */
.valaxy-nav .nav-item {
  color: var(--hty-text-color);
  font-size: 1.5rem !important;
  opacity: 0.6;
  transition: all 0.2s;
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  padding: 5px !important;
}
.valaxy-nav .nav-item:hover {
  opacity: 1;
  color: var(--hty-primary-color);
  transform: scale(1.15);
}
.valaxy-nav .nav-item svg {
  width: 1.6rem !important;
  height: 1.6rem !important;
  stroke-width: 1.5 !important;
}
.valaxy-nav .nav-item span {
  font-size: 1.05rem !important;
  margin-left: 6px !important;
}
/* =============================================== */
/* 🏗️ 2. 全局防干扰清理 */
/* =============================================== */
body:not(.is-home) {
  /* 隐藏原主题会干扰排版的自带侧边栏按钮和废弃按钮 */
  .sidebar-toggle, #menu-btn, .sidebar #toggle-mode-btn { display: none !important; }

  /* =============================================== */
  /* 📐 3. Grid 三栏卡片网格布局 */
  /* =============================================== */
  @media screen and (min-width: 1200px) {
    .container {
      display: grid !important;
      justify-content: center !important;
      grid-template-columns: 280px minmax(0, 1fr) 260px !important;
      grid-template-rows: auto auto !important;
      gap: 30px !important;
      max-width: 85vw !important;
      margin: 90px auto 40px auto !important; /* 顶部让出导航栏高度 */
      padding: 0 20px !important;
      align-items: start;
    }

    /* 拯救页脚：跨越三栏沉底 */
    footer, #footer {
      grid-column: 1 / -1;
      grid-row: 3 !important;
      margin-top: 40px !important;
    }
  }

  /* 核心卡片 1：中间主内容区 */
  #content {
    grid-column: 2 !important;
    grid-row: 2 !important;
    width: auto !important;
    min-width: 0 !important;
    max-width: none !important;
    background: var(--my-card-bg) !important;
    border-radius: var(--my-radius) !important;
    box-shadow: var(--my-shadow) !important;
    padding: 40px 50px !important;
    margin: 0 !important;
    opacity: 1 !important;
  }

  /* 核心卡片 2：左侧边栏 */
  .sidebar {
    grid-column: 1 !important;
    grid-row: 2 !important;
    position: sticky !important;
    top: 90px !important; /* 吸顶距离完美对接导航栏 */
    background: var(--my-card-bg) !important;
    border-right: none !important;
    border-radius: var(--my-radius) !important;
    box-shadow: var(--my-shadow) !important;
    padding: 30px 20px !important;
    margin: 0 !important;
    width: auto !important;
    opacity: 1 !important;
  }
}

/* 核心卡片 3：右侧目录区 */
.right-sidebar {
  grid-column: 3 !important;
  grid-row: 2 !important;
  position: sticky;
  top: 90px !important;
  background: var(--my-card-bg) !important;
  border-radius: var(--my-radius) !important;
  box-shadow: var(--my-shadow) !important;
  padding: 24px;
  margin: 0 !important;
  max-height: calc(100vh - 120px);
  overflow-y: auto;
  opacity: 1 !important;
}

/* --- 彻底重写右侧目录样式：灰细精致版 --- */
.right-sidebar::before {
  content: "文章目录";
  display: block;
  font-size: 1rem;
  font-weight: bold;
  color: var(--hty-text-color);
  text-align: center;
  margin-bottom: 20px;
  padding-bottom: 15px;
  border-bottom: 1px dashed rgba(150, 150, 150, 0.3);
}
.right-sidebar ol, .right-sidebar ul { list-style: none !important; padding-left: 0 !important; margin: 0 !important; }
.right-sidebar .toc-number { display: none !important; }
.right-sidebar .toc-child { padding-left: 15px !important; }
.right-sidebar li.toc-item { margin-bottom: 10px !important; line-height: 1.4 !important; }
.right-sidebar a.toc-link {
  font-size: 0.9rem !important;
  color: var(--hty-text-color) !important;
  opacity: 0.7;
  text-decoration: none !important;
  border-bottom: none !important;
  display: block;
  transition: all 0.2s ease;
}
.right-sidebar a.toc-link:hover, .right-sidebar a.toc-link.active {
  opacity: 1;
  color: var(--hty-primary-color) !important;
  transform: translateX(3px);
}

/* =============================================== */
/* 📱 4. 手机端响应式降级处理 */
/* =============================================== */
@media screen and (max-width: 1199px) {
  /* 手机端隐藏中间标题和右侧目录防挤爆 */
  .valaxy-nav .nav-center { display: none !important; }
  .right-sidebar { display: none !important; }
  
  body:not(.is-home) .container {
    display: block !important;
    padding: 0 15px !important;
    margin-top: 80px !important; 
  }
  body:not(.is-home) .sidebar {
    position: relative !important;
    top: 0 !important;
    width: 100% !important;
    margin: 20px auto !important;
  }
  body:not(.is-home) #content {
    margin: 20px 0 !important;
    padding: 20px !important;
  }
}
/* 🔪 解除宽度封印（严格限定在非首页，保护主页排版！） */
body:not(.is-home) #content .post-card,
body:not(.is-home) #content .post-block,
body:not(.is-home) #content .markdown-body {
  max-width: 100% !important;
  width: 100% !important;
}
/* ================================================= */
/* 📱 5. 终极手机端适配：APP 级侧边抽屉交互 */
/* ================================================= */

/* 默认在电脑端隐藏手机特有组件 */
#mobile-menu-btn, #mobile-overlay, #mobile-toc-btn { display: none; }
/* 默认状态（电脑端）：把汉堡菜单藏起来 */
#mobile-menu-btn {
  display: none !important;
}

@media screen and (max-width: 768px) {
  
  /* --- 1. 顶部导航栏变形 --- */
  .desktop-nav-links { display: none !important; } /* 隐藏左侧那一排冗余图标 */
  #mobile-menu-btn { display: inline-flex !important; } /* 唤醒汉堡菜单 */
  
  .valaxy-nav .nav-center {
    display: flex !important; /* 恢复中间的博客标题 */
    position: absolute !important;
    left: 50% !important;
    transform: translateX(-50%) !important;
    width: auto !important;
  }
  /* 手机端空间小，滚动时不显示文章标题，只保留网站名 */
  .valaxy-nav .article-title { display: none !important; } 

  /* --- 2. 暗黑遮罩层 --- */
  #mobile-overlay {
    display: block;
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    z-index: 2000;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
  }
  /* 只要任意抽屉打开，遮罩层就浮现 */
  body.sidebar-open #mobile-overlay,
  body.toc-open #mobile-overlay {
    opacity: 1;
    visibility: visible;
  }

  /* --- 3. 核心：左侧个人卡片变抽屉！ --- */
  body:not(.is-home) .sidebar {
    position: fixed !important;
    top: 0 !important;
    left: -320px !important; /* 默认藏在屏幕左边外面 */
    width: 280px !important;
    height: 100vh !important;
    z-index: 2001 !important;
    margin: 0 !important;
    border-radius: 0 20px 20px 0 !important; /* 只给右边加圆角，更像抽屉 */
    transition: transform 0.35s cubic-bezier(0.25, 0.8, 0.25, 1) !important;
    overflow-y: auto;
    padding-top: 50px !important; /* 给顶部留点呼吸空间 */
  }
  /* 点击汉堡按钮后，滑入屏幕！ */
  body.sidebar-open .sidebar {
    transform: translateX(320px) !important; 
  }

  /* --- 4. 核心：右侧文章目录变抽屉！ --- */
  .right-sidebar {
    display: block !important;
    position: fixed !important;
    top: 0 !important;
    right: -320px !important; /* 默认藏在屏幕右边外面 */
    width: 260px !important;
    height: 100vh !important;
    z-index: 2001 !important;
    margin: 0 !important;
    border-radius: 20px 0 0 20px !important;
    transition: transform 0.35s cubic-bezier(0.25, 0.8, 0.25, 1) !important;
    padding-top: 50px !important;
  }
  body.toc-open .right-sidebar {
    transform: translateX(-320px) !important;
  }

  /* 悬浮在右下角的召唤目录按钮 */
  #mobile-toc-btn {
    display: flex;
    position: fixed;
    bottom: 30px;
    right: 20px;
    width: 48px;
    height: 48px;
    background: var(--my-card-bg);
    border-radius: 50%; /* 圆形悬浮球 */
    box-shadow: 0 8px 24px rgba(0,0,0,0.15);
    z-index: 1999;
    justify-content: center;
    align-items: center;
    font-size: 1.5rem;
    color: var(--hty-primary-color);
    cursor: pointer;
    transition: transform 0.2s;
  }
  #mobile-toc-btn:active { transform: scale(0.9); }

  @media screen and (max-width: 768px) {
  /* --- 1. 导航栏重塑：拒绝叠罗汉 --- */
  .valaxy-nav {
    display: flex !important; /* 强制改回弹性盒子 */
    justify-content: space-between !important;
    grid-template-columns: none !important; /* 彻底删掉 Grid 规则 */
    padding: 0 10px !important;
  }

  /* 左侧和右侧图标组：不许拉伸，给中间腾位置 */
  .valaxy-nav .nav-left,
  .valaxy-nav .nav-right {
    flex: 0 0 auto !important;
    gap: 4px !important; /* 手机端图标紧凑点 */
  }

  .desktop-nav-links { display: none !important; } /* 隐藏电脑端多余图标 */
 #mobile-menu-btn {
    display: inline-flex !important;
  }
  .desktop-only-icon {
    display: none !important;
  }

  /* 中间标题：绝对居中且不许压人 */
  .valaxy-nav .nav-center {
    position: absolute !important;
    left: 50% !important;
    top: 0;
    transform: translateX(-50%) !important;
    width: 40% !important; /* 核心：限制宽度，防止挤到两边的图标 */
    display: flex !important;
    justify-content: center !important;
    pointer-events: none; /* 防止遮挡点击图标 */
  }

  .valaxy-nav .site-name {
    font-size: 1rem !important; /* 手机标题稍微缩小点，防溢出 */
    letter-spacing: 0px !important;
  }

  .valaxy-nav .nav-item {
    padding: 5px !important;
  }
  .valaxy-nav .nav-item svg {
    width: 1.25rem !important;
    height: 1.25rem !important;
  }
  }
  /* --- 以下保持之前的抽屉逻辑不变 --- */
  #mobile-overlay {
    display: block; position: fixed; top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0, 0, 0, 0.5); backdrop-filter: blur(4px); z-index: 2000;
    opacity: 0; visibility: hidden; transition: all 0.3s ease;
  }
  body.sidebar-open #mobile-overlay, body.toc-open #mobile-overlay { opacity: 1; visibility: visible; }
  body:not(.is-home) .sidebar {
    position: fixed !important; top: 0 !important; left: -320px !important;
    width: 280px !important; height: 100vh !important; z-index: 2001 !important;
    margin: 0 !important; border-radius: 0 20px 20px 0 !important;
    transition: transform 0.35s cubic-bezier(0.25, 0.8, 0.25, 1) !important;
    overflow-y: auto; padding-top: 50px !important;
  }
  body.sidebar-open .sidebar { transform: translateX(320px) !important; }
}
/* ================================================= */
/* 💻 修复：代码块防溢出与丝滑滚动优化 */
/* ================================================= */
.markdown-body pre,
.markdown-body .highlight {
  max-width: 100% !important;     /* 绝不允许代码块比手机屏幕还宽 */
  width: 100% !important;
  overflow-x: auto !important;    /* 内容太长时，自动出现横向滚动条 */
  box-sizing: border-box !important;
  -webkit-overflow-scrolling: touch !important; /* 🍎 核心：让 iPhone 等手机端手指滑动极其丝滑 */
  padding-bottom: 5px !important; /* 给底部的滚动条留一点呼吸空间，防遮挡文字 */
}

/* 🎨 顺手美化一下滚动条，让它看起来更精致，不那么突兀 */
.markdown-body .highlight::-webkit-scrollbar,
.markdown-body pre::-webkit-scrollbar {
  height: 6px !important;         /* 滚动条变细一点 */
}
.markdown-body .highlight::-webkit-scrollbar-thumb,
.markdown-body pre::-webkit-scrollbar-thumb {
  background: rgba(150, 150, 150, 0.4) !important; /* 半透明灰色 */
  border-radius: 4px !important;  /* 圆角滚动条 */
}
.markdown-body .highlight::-webkit-scrollbar-track,
.markdown-body pre::-webkit-scrollbar-track {
  background: transparent !important; /* 轨道全透明 */
}